---
const { t } = Astro.locals;
---

<section class="scan-error section hidden" id="scan-error-section"
  data-i18n={JSON.stringify({
    no_face: { title: t('scan.error.noFace.title'), desc: t('scan.error.noFace.desc') },
    bad_pose: { title: t('scan.error.badPose.title'), desc: t('scan.error.badPose.desc') },
    camera_denied: { title: t('scan.error.camera.title'), desc: t('scan.error.camera.desc') },
    invalid_landmarks: { title: t('scan.error.generic.title'), desc: t('scan.error.generic.desc') },
  })}
>
  <div class="container text-center">
    <div class="error__card glass-card">
      <div class="error__icon">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="20" stroke="var(--color-tertiary)" stroke-width="2"/>
          <path d="M24 16v10" stroke="var(--color-tertiary)" stroke-width="2" stroke-linecap="round"/>
          <circle cx="24" cy="32" r="1.5" fill="var(--color-tertiary)"/>
        </svg>
      </div>
      <h3 class="error__title" id="scan-error-title">Something went wrong</h3>
      <p class="error__desc" id="scan-error-desc">Please try again with a different photo.</p>
      <button class="btn-primary" id="scan-error-retry" type="button">{t('scan.error.retry')}</button>
    </div>
  </div>
</section>

<style>
  .error__card {
    max-width: 440px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-2xl);
  }

  .error__icon {
    margin-bottom: var(--space-lg);
  }

  .error__title {
    color: var(--color-tertiary);
    margin-bottom: var(--space-sm);
  }

  .error__desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .hidden { display: none !important; }
</style>

<script>
  const ERROR_MESSAGES: Record<string, { title: string; desc: string }> = JSON.parse(
    document.getElementById('scan-error-section')?.dataset.i18n || '{}'
  );

  window.addEventListener('visevo:scan-error', ((e: CustomEvent) => {
    const { type, message } = e.detail;
    const info = ERROR_MESSAGES[type] || { title: 'Something went wrong', desc: message || 'Please try again.' };

    document.getElementById('scan-error-title')!.textContent = info.title;
    document.getElementById('scan-error-desc')!.textContent = info.desc;
  }) as EventListener);

  document.getElementById('scan-error-retry')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('visevo:scan-reset'));
  });
</script>
