---
const { t } = Astro.locals;
---

<section class="scan-hero">
  <div class="container text-center">
    <p class="section-label reveal">{t('scan.hero.label')}</p>
    <h1 class="scan-hero__title reveal">
      {t('scan.hero.title1')}<br /><span class="gradient-text">{t('scan.hero.title2')}</span>
    </h1>
    <p class="scan-hero__subtitle reveal">
      {t('scan.hero.subtitle')}
    </p>
  </div>
</section>

<style>
  .scan-hero {
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
  }

  .scan-hero__title {
    margin-bottom: var(--space-lg);
  }

  .scan-hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 48ch;
    margin-left: auto;
    margin-right: auto;
  }
</style>
