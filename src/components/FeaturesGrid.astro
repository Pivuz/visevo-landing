---
const features = [
  {
    title: 'Glow Score',
    description: 'One unified number that captures your facial wellness. Track it daily, see it grow.',
    accent: 'var(--glow-glowing)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.5"/><path d="M14 7v7l4.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Skin Vitality',
    description: 'AI-powered skin analysis tracks clarity, hydration, and texture across every scan.',
    accent: 'var(--color-secondary)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3c0 0-9 8-9 14a9 9 0 1 0 18 0c0-6-9-14-9-14z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Facial Balance',
    description: 'Understand your proportions and symmetry with precise, non-judgmental measurements.',
    accent: '#7DD3FC',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="20" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="14" y1="4" x2="14" y2="24" stroke="currentColor" stroke-width="1" opacity="0.5"/><line x1="4" y1="14" x2="24" y2="14" stroke="currentColor" stroke-width="1" opacity="0.5"/></svg>`,
  },
  {
    title: 'Streaks & XP',
    description: 'Build daily habits that stick. Every scan earns XP, every streak milestone feels earned.',
    accent: 'var(--glow-radiant)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6l2-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Trend Insights',
    description: 'Weekly and monthly reports show what\'s working. Data stories, not data dumps.',
    accent: 'var(--color-tertiary)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 21l6-8 5 5 9-12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Share Cards',
    description: 'Beautiful, pre-designed cards to share your Glow Score on Instagram, TikTok, or with friends.',
    accent: 'var(--color-primary)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="8" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="21" r="3" stroke="currentColor" stroke-width="1.5"/><line x1="10.5" y1="12.5" x2="17.5" y2="8.5" stroke="currentColor" stroke-width="1.5"/><line x1="10.5" y1="15.5" x2="17.5" y2="19.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
];
---

<section class="features section" id="features">
  <div class="container text-center">
    <p class="section-label reveal">Features</p>
    <h2 class="section-title reveal">Everything You Need to Glow</h2>
    <p class="section-subtitle reveal">
      Powerful tools wrapped in a beautiful, intuitive experience.
    </p>

    <div class="features__grid">
      {features.map((feature) => (
        <div class="glass-card features__card reveal" style={`--card-accent: ${feature.accent}`}>
          <div class="features__icon" set:html={feature.icon} />
          <h3 class="features__title">{feature.title}</h3>
          <p class="features__desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-3xl);
  }

  .features__card {
    text-align: left;
    border-top: 2px solid var(--card-accent);
  }

  .features__icon {
    color: var(--card-accent);
    margin-bottom: var(--space-md);
  }

  .features__title {
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }

  .features__desc {
    font-size: 0.875rem;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
