---
const { t } = Astro.locals;

const features = [
  {
    title: t('feat.glowScore.title'),
    description: t('feat.glowScore.desc'),
    accent: 'var(--glow-glowing)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.5"/><path d="M14 7v7l4.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: t('feat.skinVitality.title'),
    description: t('feat.skinVitality.desc'),
    accent: 'var(--color-secondary)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3c0 0-9 8-9 14a9 9 0 1 0 18 0c0-6-9-14-9-14z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: t('feat.aiCoach.title'),
    description: t('feat.aiCoach.desc'),
    accent: '#7DD3FC',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="10" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M6 24c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M18 8l3-3M10 8l-3-3M14 4V1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: t('feat.streaks.title'),
    description: t('feat.streaks.desc'),
    accent: 'var(--glow-radiant)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6l2-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: t('feat.trends.title'),
    description: t('feat.trends.desc'),
    accent: 'var(--color-tertiary)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 21l6-8 5 5 9-12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: t('feat.share.title'),
    description: t('feat.share.desc'),
    accent: 'var(--color-primary)',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="8" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="21" r="3" stroke="currentColor" stroke-width="1.5"/><line x1="10.5" y1="12.5" x2="17.5" y2="8.5" stroke="currentColor" stroke-width="1.5"/><line x1="10.5" y1="15.5" x2="17.5" y2="19.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
];
---

<section class="features section" id="features">
  <div class="container text-center">
    <p class="section-label reveal">{t('feat.label')}</p>
    <h2 class="section-title reveal">{t('feat.title')}</h2>
    <p class="section-subtitle reveal">
      {t('feat.subtitle')}
    </p>

    <div class="features__grid">
      {features.map((feature) => (
        <div class="glass-card features__card reveal" style={`--card-accent: ${feature.accent}`}>
          <div class="features__icon" set:html={feature.icon} />
          <h3 class="features__title">{feature.title}</h3>
          <p class="features__desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-3xl);
  }

  .features__card {
    text-align: left;
    border-top: 2px solid var(--card-accent);
  }

  .features__icon {
    color: var(--card-accent);
    margin-bottom: var(--space-md);
  }

  .features__title {
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }

  .features__desc {
    font-size: 0.875rem;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
