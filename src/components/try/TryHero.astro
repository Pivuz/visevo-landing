---
---

<section class="try-hero">
  <div class="container text-center">
    <p class="section-label">AI-Powered Analysis</p>
    <h1 class="try-hero__title">
      Discover Your <span class="gradient-text">Glow Score</span>
    </h1>
    <p class="try-hero__subtitle">
      Upload a photo or use your camera to get an instant facial structure analysis
      — powered by the same AI behind the Visevo app.
    </p>
    <div class="try-hero__privacy">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M8 1L2 4v4c0 3.5 2.5 6.3 6 7 3.5-.7 6-3.5 6-7V4L8 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
        <path d="M6 8l1.5 1.5L10 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>100% in-browser. Your photo never leaves your device.</span>
    </div>
  </div>
</section>

<style>
  .try-hero {
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
  }

  .try-hero__title {
    margin-bottom: var(--space-lg);
  }

  .try-hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 52ch;
    margin: 0 auto var(--space-lg);
  }

  .try-hero__privacy {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8125rem;
    color: var(--glow-balanced);
    padding: var(--space-sm) var(--space-md);
    background: rgba(94, 234, 212, 0.08);
    border: 1px solid rgba(94, 234, 212, 0.15);
    border-radius: var(--radius-full);
  }
</style>
