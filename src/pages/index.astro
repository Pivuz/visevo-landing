---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ValueProps from '../components/ValueProps.astro';
import FeaturesGrid from '../components/FeaturesGrid.astro';
import GlowScoreSection from '../components/GlowScoreSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import TrustSection from '../components/TrustSection.astro';
import WaitlistCTA from '../components/WaitlistCTA.astro';
import ComingSoon from '../components/ComingSoon.astro';
import Footer from '../components/Footer.astro';

const { t } = Astro.locals;
---

<BaseLayout title={t('meta.homeTitle')} description={t('meta.homeDesc')}>
  <Header />
  <main>
    <HeroSection />
    <ValueProps />
    <FeaturesGrid />
    <GlowScoreSection />
    <HowItWorks />
    <TrustSection />
    <WaitlistCTA />
    <ComingSoon />
  </main>
  <Footer />
</BaseLayout>
